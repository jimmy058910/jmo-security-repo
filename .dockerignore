# JMo Security Docker Build Exclusions (Phase 2 Optimization: Layer Caching + 8 MB savings)
# Prevents copying unnecessary files to Docker build context
# This reduces context size AND improves layer cache hit rates

# =============================================================================
# VERSION CONTROL (large directory, not needed in image)
# =============================================================================
.git/
.github/
.gitignore
.gitattributes

# =============================================================================
# DEVELOPMENT AND TESTING (not needed in runtime)
# =============================================================================
dev-only/
tests/
test-data/
*.test.js
*.spec.py
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
.tox/
htmlcov/
.hypothesis/

# =============================================================================
# AI/LLM TOOLING (development only)
# =============================================================================
.claude/
.mcp.json
.mcp.json.example
.mcp-skills/
.serena/

# =============================================================================
# DOCUMENTATION (not needed in runtime image)
# =============================================================================
*.md
!README.md
docs/
CHANGELOG.md
CONTRIBUTING.md
CONTRIBUTORS.md
CODE_OF_CONDUCT.md

# =============================================================================
# IDE AND EDITOR FILES
# =============================================================================
.vscode/
.idea/
.devcontainer/
.vercel/
*.swp
*.swo
*~
.editorconfig

# =============================================================================
# CI/CD AND LINTING CONFIG (not needed in image)
# =============================================================================
.pre-commit-config.yaml
.pre-commit-hooks.yaml
.yamllint.yaml
.ruff.toml
.ruff_cache/
.mypy_cache/
.bandit
codecov.yml
.readthedocs.yaml
.markdownlint-cli2.jsonc
.markdownlintignore
.guardrails-allowlist
.trufflehog-exclude.txt

# =============================================================================
# BUILD ARTIFACTS
# =============================================================================
*.egg-info/
dist/
build/
*.whl
*.tar.gz
node_modules/
package-lock.json

# =============================================================================
# RESULTS AND RUNTIME DATA (not needed in base image)
# =============================================================================
results/
.jmo/
*.log
*.out
*.err

# =============================================================================
# TEMPORARY AND OS FILES
# =============================================================================
tmp/
temp/
*.tmp
*.bak
*.orig
Thumbs.db
.DS_Store

# =============================================================================
# PACKAGING (Docker variants handled by specific Dockerfiles)
# =============================================================================
packaging/
samples/
assets/

# =============================================================================
# VIRTUAL ENVIRONMENTS (never include in image)
# =============================================================================
.venv/
venv/
.env

# =============================================================================
# KEEP CRITICAL FILES (override exclusions)
# =============================================================================
!.dockerignore
!Dockerfile*
!pyproject.toml
!jmo.yml
!versions.yaml
