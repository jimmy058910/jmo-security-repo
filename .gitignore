# Archived documentation moved to dev-only/archive/ (not tracked)

# Private local scripts and outputs (developer-only workspace)
/dev-only

# MCP configuration with sensitive tokens (keep .mcp.json.example in repo)
.mcp.json

# Claude Code user-specific configuration (open-source project)
# Use .claude/* (not .claude/) so specific subpaths can be re-included below.
# Git cannot re-include files under a directory excluded with a trailing slash.
.claude/*
# Exception: path-scoped AI rules are shared conventions (subprocess security,
# cross-platform testing, adapter patterns) that apply to all contributors.
!.claude/rules/
# Note: files already tracked under .claude/ (e.g. skills/INDEX.md,
# skills/jmo-e2e-verify/SKILL.md) stay tracked because git does not
# re-ignore paths that are already in the index.

# Test scan result directories (local testing artifacts)
test-juice-results/
samples/fixtures/infra-demo/docker-test-results/

# Skill Seekers analysis artifacts (local development, not for public repo)
skill_seekers/

# Paperclip local artifacts
paperclip/

# Hypothesis property-based testing cache (test artifacts, not source)
.hypothesis/

# JMo local workspace (scan history database with findings, potentially secrets)
# This is the REPOSITORY .jmo/ directory, not the user's HOME ~/.jmo/
# - Repository .jmo/: SQLite scan history (history.db) - contains findings, should NOT be committed
# - User HOME ~/.jmo/: User config (schedules.json, config.yml, policies) - lives outside repo
# Note: Use --history-db flag to store database elsewhere if needed
.jmo/

# Node.js dependencies (API)
node_modules/
scripts/api/node_modules/
scripts/api/.vercel/
.vercel

# Environment variable files
.env
.env.local
.env.*.local

# Cryptographic keys and certificates (security-critical files)
*.pem
*.key
# Secret/credential files: broad net by design. A committed secret is permanent
# in git history (false negative = catastrophic); a wrongly-ignored SOURCE file
# is visible and recoverable (false positive = cheap). Re-include source-code
# extensions so adapters/tests/policies (semgrep_secrets_adapter.py,
# zero-secrets.rego, test_secrets_management.py) aren't silently dropped, while
# real secret DATA files (.json/.yaml/.env/.txt) stay ignored.
*secret*
*credentials*
!*secret*.py
!*secret*.rego
!*credentials*.py
!*credentials*.rego

# Metrics collection output (maintainer-only, contains sensitive analytics)
/metrics/

# Additional generated artifacts
*.sarif
*_report.html
test-*.html
*-dashboard.html
# Exception: Keep test fixtures for CI (must come AFTER ignore patterns)
!tests/fixtures/dashboard/*.html
# Test artifacts (image lists from scans)
*-images.txt
diff-data.json

# Playwright screenshots
.playwright-mcp/
*.playwright.png

# E2E visual test screenshots
e2e-screenshots/

# Serena MCP auto-generated project config
.serena/

# Nightshift automation config (symlink to dev-only/infrastructure/nightshift.yaml)
nightshift.yaml

# Conductor orchestration files (local development artifacts)
/conductor/
tests/integration/juice_shop_fixture/

# uv lockfile: the canonical dev-dep lockfile is requirements-dev.txt (pip-tools).
# Tracking uv.lock duplicates resolution and makes Dependabot emit uv-group PRs
# whose resolver diverges from the CI pip-tools resolver. Users who prefer uv
# can regenerate their own local uv.lock from requirements-dev.in.
uv.lock
