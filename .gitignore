# Local virtual environments
.venv/
.venv-pypi/
.tmp-venv-pypi/
.post-release-venv/
venv*/

# Claude Code temp directories (created during sessions)
tmpclaude-*
nul

# Coverage artifacts
.coverage*
coverage.xml
coverage.json

# VS Code and editor junk
.vscode/
*.swp
*.swo

# Python caches
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/
*.egg-info/

# Python distribution artifacts (wheel files should not be committed)
*.whl
*.egg
# Review tracking artifacts
REVIEW.md
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc

# Backup files
*.bak
*.old
*_old.*
*_backup.*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test results and temporary files
/tmp/
*.log
.coverage
htmlcov/
.pytest_cache/

# Security scan results (don't commit actual scan results)
security-results-*/
results/
results-*/

# Sample fixture scan outputs (regenerated via `make regenerate-samples`)
samples/fixtures/*/sample-results/

# Test reports and documentation (comprehensive testing artifacts)
docs/comprehensive-test-report.md

# (formerly) Local roadmap file removed; keep repo docs public

# Private planning documents (developer-specific, not for public repo)
DEVELOPER_ROADMAP.md
BUSINESS_MODEL.md
docs/VERSION_TAG.md
BUSINESS_PLAN.md
PRODUCT_DEFINITION.md
docs/COMPLETENESS_ANALYZER.md

# Archived documentation (historical reference)
# Archive structure is tracked (README.md, v0.6.0/)
# Individual archived files are gitignored
docs/archive/merged/*
!docs/archive/README.md
!docs/archive/v0.6.0/

# Private local scripts and outputs (developer-only workspace)
/dev-only

# MCP configuration with sensitive tokens (keep .mcp.json.example in repo)
.mcp.json

# Claude Code user-specific configuration (open-source project)
# Ignore contents of .claude/ but allow ralph-cli-testing subdirectory
.claude/*
!.claude/ralph-cli-testing/
# But ignore runtime artifacts within Ralph testing
.claude/ralph-cli-testing/iteration-logs/
.claude/ralph-cli-testing/test-results.json
.claude/ralph-cli-testing/fixtures/results-*/
samples/fixtures/infra-demo/docker-test-results/

# Skill Seekers analysis artifacts (local development, not for public repo)
skill_seekers/

# Hypothesis property-based testing cache (test artifacts, not source)
.hypothesis/

# JMo local workspace (scan history database with findings, potentially secrets)
# This is the REPOSITORY .jmo/ directory, not the user's HOME ~/.jmo/
# - Repository .jmo/: SQLite scan history (history.db) - contains findings, should NOT be committed
# - User HOME ~/.jmo/: User config (schedules.json, config.yml, policies) - lives outside repo
# Note: Use --history-db flag to store database elsewhere if needed
.jmo/

# Node.js dependencies (API)
node_modules/
scripts/api/node_modules/
scripts/api/.vercel/
.vercel

# Environment variable files
.env
.env.local
.env.*.local

# Cryptographic keys and certificates (security-critical files)
*.pem
*.key
*secret*
*credentials*

# Metrics collection output (maintainer-only, contains sensitive analytics)
/metrics/
coverage/

# Additional generated artifacts
*.sarif
*_report.html
test-*.html
*-dashboard.html
# Exception: Keep test fixtures for CI (must come AFTER ignore patterns)
!tests/fixtures/dashboard/*.html
# Test artifacts (image lists from scans)
*-images.txt

# Playwright screenshots
.playwright-mcp/
*.playwright.png

# Serena MCP auto-generated project config
.serena/

# Backup files (additional patterns)
*.backup
*.new
*.orig

# Claude Code temporary working directories
tmpclaude-*/

# Conductor orchestration files (local development artifacts)
/conductor/
